# Environment Variables for AI Image Processor

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ai_image_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=Asia/Ho_Chi_Minh
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password

# Server
PORT=8080

# Gemini Vision API
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# YOLOv5 (OpenCV DNN)
APP_YOLO_ENABLED=true
APP_YOLO_MODEL_PATH=./src/main/resources/models/yolov5s.onnx
APP_YOLO_CONFIDENCE_THRESHOLD=0.35
APP_YOLO_NMS_THRESHOLD=0.45

# CORS (comma-separated)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
